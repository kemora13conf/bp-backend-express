# --- Environment ------------------------------------------------------
NODE_ENV=development                  # development | staging | production | test

# --- Server ----------------------------------------------------------
PORT=3000
HOST=localhost
# Clustering is handled by PM2 (see ecosystem.config.cjs), not the app.
# TLS is terminated by the reverse proxy (nginx) — the app speaks plain HTTP.

# --- Security --------------------------------------------------------
CORS_ORIGINS=                         # csv allowlist; empty = none, "*" = any (dev only)
CORS_CREDENTIALS=false                # allow cookies / Authorization cross-origin
TRUST_PROXY=false                     # false | true | <hops> | loopback — behind a proxy use the hop count
BODY_LIMIT=100kb                      # max JSON request body
RATE_LIMIT_WINDOW_MS=60000            # rate-limit window (ms)
RATE_LIMIT_MAX=100                    # max requests per IP per window (global)
RATE_LIMIT_AUTH_MAX=10                # stricter cap for auth routes

# --- Database (MongoDB) ----------------------------------------------
DATABASE_PROTOCOL=mongodb             # mongodb | mongodb+srv (srv ignores DATABASE_PORT)
DATABASE_HOST=localhost
DATABASE_PORT=27017
DATABASE_NAME=bp-express
DATABASE_USER=
DATABASE_PASSWORD=

# --- Redis (cache + BullMQ) ------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                        # optional
REDIS_DB=0                             # logical db index (default: 0)

# --- Queue worker ----------------------------------------------------
WORKER_INLINE=false                   # true|false — run the worker in the web process (dev only; default: false)
WORKER_CONCURRENCY=5                  # max concurrent jobs per worker (default: 5)

# --- JWT -------------------------------------------------------------
JWT_ALGORITHM=RS256                   # HS256 | RS256 | ES256 (default: RS256)
JWT_PRIVATE_KEY=change-me             # private key for RS256/ES256, or secret for HS256
JWT_PUBLIC_KEY=change-me              # public key for RS256/ES256
JWT_EXPIRES_IN=1h                     # e.g. "1h", "7d", "30d"
JWT_REFRESH_EXPIRES_IN=7d             # e.g. "1h", "7d", "30d"

# --- Mailer (SMTP) ---------------------------------------------------
MAILER_FROM=no-reply@example.com
MAILER_HOST=smtp.example.com
MAILER_PORT=587
MAILER_SECURE=false                   # true for port 465, false for 587/STARTTLS
MAILER_AUTH_USER=
MAILER_AUTH_PASS=
MAILER_QUEUE_ENABLED=true             # true|false — enqueue mail via BullMQ vs send inline (default: true)
MAILER_LOGGING_ENABLED=true           # true|false — nodemailer transport logging (default: false)

# --- Logging (optional) ----------------------------------------------
# All optional — defaults are applied in src/config/logger.ts.
LOG_LEVEL=info                        # fatal|error|warn|info|debug|trace (default: debug in dev, info in prod)
LOG_DIR=./logs                        # directory for rotated log files (default: ./logs)
LOG_TO_FILE=true                      # true|false (default: true)

# --- i18n (optional) -------------------------------------------------
# All optional — defaults are applied in src/lib/i18n.ts.
I18N_FALLBACK_LANGUAGE=en             # default: en
I18N_SUPPORTED_LANGUAGES=en,fr        # comma-separated (default: en)
I18N_DEFAULT_NAMESPACE=core           # default: core
