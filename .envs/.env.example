# --- Environment ------------------------------------------------------
NODE_ENV=development                  # development | production | test

# --- Server ----------------------------------------------------------
PORT=3000
HOST=localhost

# --- Database (MongoDB) ----------------------------------------------
DATABASE_PROTOCOL=mongodb             # mongodb | mongodb+srv (srv ignores DATABASE_PORT)
DATABASE_HOST=localhost
DATABASE_PORT=27017
DATABASE_NAME=bp-express
DATABASE_USER=
DATABASE_PASSWORD=

# --- JWT -------------------------------------------------------------
JWT_SECRET=change-me                  # use a long random secret
JWT_EXPIRES_IN=1h

# --- Mailer (SMTP) ---------------------------------------------------
MAILER_FROM=no-reply@example.com
MAILER_HOST=smtp.example.com
MAILER_PORT=587
MAILER_SECURE=false                   # true for port 465, false for 587/STARTTLS
MAILER_AUTH_USER=
MAILER_AUTH_PASS=
MAILER_QUEUE_ENABLED=true             # app-specific (not validated by the env schema)
MAILER_LOGGING_ENABLED=true           # app-specific (not validated by the env schema)

# --- Logging (optional) ----------------------------------------------
# All optional — defaults are applied in src/lib/logger.ts.
LOG_LEVEL=info                        # fatal|error|warn|info|debug|trace (default: debug in dev, info in prod)
LOG_DIR=./logs                        # directory for rotated log files (default: ./logs)
LOG_TO_FILE=true                      # true|false (default: true)
