{
  "name": "bp-backend-express",
  "packageManager": "yarn@4.12.0",
  "type": "module",
  "imports": {
    "#/*": "./build/*",
    "#config/*": "./build/config/*",
    "#lib/*": "./build/lib/*",
    "#helpers/*": "./build/helpers/*",
    "#modules/*": "./build/modules/*",
    "#packages/*": "./build/packages/*"
  },
  "scripts": {
    "//  Develop  ─────────────────────────────────": "",
    "start:dev": "NODE_ENV=development nodemon",

    "//  Build  ───────────────────────────────────": "",
    "clean": "node scripts/clean.mjs",
    "copy:assets": "node scripts/copy-assets.mjs",
    "build": "yarn clean && tsc && tsc-alias && yarn copy:assets",

    "//  Run · production  ────────────────────────": "",
    "start:prod": "NODE_ENV=production node build/Application.js",
    "start:worker": "NODE_ENV=production node build/worker.js",

    "//  PM2 · build first  ───────────────────────": "",
    "pm2:dev": "yarn build && pm2 start ecosystem.config.cjs --env development",
    "pm2:staging": "yarn build && pm2 start ecosystem.config.cjs --env staging",
    "pm2:prod": "yarn build && pm2 start ecosystem.config.cjs --env production",
    "pm2:reload": "pm2 reload ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:delete": "pm2 delete ecosystem.config.cjs",
    "pm2:logs": "pm2 logs --raw | pino-pretty",

    "//  Emails · React Email preview  ────────────": "",
    "email:dev": "email dev --dir src/emails/preview --port 3001",
    "email:export": "email export --dir src/emails/preview --outDir out",

    "//  Keys  ────────────────────────────────────": "",
    "keys:jwt": "node scripts/generate-jwt-keys.mjs"
  },
  "dependencies": {
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.9",
    "bullmq": "^5.79.2",
    "colorette": "^2.0.20",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "glob": "^13.0.6",
    "i18next": "^26.3.1",
    "i18next-fs-backend": "^2.6.6",
    "i18next-http-middleware": "^3.9.7",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.1",
    "nodemailer": "^9.0.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-roll": "^4.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rotating-file-stream": "^3.2.9",
    "tsc-alias": "^1.8.17",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@react-email/ui": "6.6.5",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9",
    "@types/node": "^26.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "pm2": "^7.0.1",
    "react-email": "^6.6.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  }
}
