{
  "name": "bp-backend-express",
  "packageManager": "yarn@4.12.0",
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js"
  },
  "imports": {
    "#/*": {
      "development": "./src/*",
      "default": "./build/*"
    }
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "tsc-alias": "^1.8.17"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsconfig-paths": "^4.2.0"
  }
}