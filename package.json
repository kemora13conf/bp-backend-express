{
  "name": "bp-backend-express",
  "packageManager": "yarn@4.12.0",
  "type": "module",
  "scripts": {
    "build": "tsc && tsc-alias",
    "dev": "NODE_ENV=development nodemon",
    "start": "NODE_ENV=production node build/src/Application.js",
    "prod": "yarn build && yarn start"
  },
  "imports": {
    "#/*": "./build/src/*",
    "#config/*": "./build/src/config/*"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "tsc-alias": "^1.8.17"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  }
}
